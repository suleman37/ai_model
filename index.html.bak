<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Ear Landmark Mapping - Module 2</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap"
        rel="stylesheet">
    <style>
        /* ========== RESET & BASE ========== */
        *,
        *::before,
        *::after {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        :root {
            --bg-primary: #0a0e1a;
            --bg-secondary: #111827;
            --bg-card: #1a1f35;
            --bg-card-hover: #222842;
            --accent-1: #6366f1;
            --accent-2: #8b5cf6;
            --accent-3: #a78bfa;
            --accent-glow: rgba(99, 102, 241, 0.25);
            --text-primary: #f1f5f9;
            --text-secondary: #94a3b8;
            --text-muted: #64748b;
            --border: rgba(99, 102, 241, 0.15);
            --border-active: rgba(99, 102, 241, 0.5);
            --success: #10b981;
            --success-bg: rgba(16, 185, 129, 0.1);
            --danger: #ef4444;
            --danger-bg: rgba(239, 68, 68, 0.1);
            --warning: #f59e0b;
            --warning-bg: rgba(245, 158, 11, 0.1);
            --radius: 12px;
            --radius-lg: 16px;
            --shadow: 0 4px 24px rgba(0, 0, 0, 0.3);
            --shadow-lg: 0 8px 40px rgba(0, 0, 0, 0.4);
            --transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }

        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
            background: var(--bg-primary);
            color: var(--text-primary);
            min-height: 100vh;
            overflow-x: hidden;
        }

        /* ========== BACKGROUND ========== */
        body::before {
            content: '';
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background:
                radial-gradient(ellipse at 20% 0%, rgba(99, 102, 241, 0.08) 0%, transparent 60%),
                radial-gradient(ellipse at 80% 100%, rgba(139, 92, 246, 0.06) 0%, transparent 60%);
            pointer-events: none;
            z-index: 0;
        }

        /* ========== LAYOUT ========== */
        .app {
            position: relative;
            z-index: 1;
            max-width: 1280px;
            margin: 0 auto;
            padding: 24px;
        }

        /* ========== HEADER ========== */
        .header {
            text-align: center;
            padding: 48px 24px 32px;
            margin-bottom: 32px;
        }

        .header-badge {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            background: linear-gradient(135deg, rgba(99, 102, 241, 0.15), rgba(139, 92, 246, 0.15));
            border: 1px solid var(--border);
            border-radius: 100px;
            padding: 6px 16px;
            font-size: 0.75rem;
            font-weight: 600;
            color: var(--accent-3);
            letter-spacing: 0.5px;
            text-transform: uppercase;
            margin-bottom: 16px;
        }

        .header-badge::before {
            content: '';
            width: 6px;
            height: 6px;
            border-radius: 50%;
            background: var(--success);
            box-shadow: 0 0 8px var(--success);
            animation: pulse-dot 2s ease-in-out infinite;
        }

        @keyframes pulse-dot {

            0%,
            100% {
                opacity: 1;
                transform: scale(1);
            }

            50% {
                opacity: 0.5;
                transform: scale(0.8);
            }
        }

        .header h1 {
            font-size: 2.5rem;
            font-weight: 800;
            background: linear-gradient(135deg, var(--text-primary) 0%, var(--accent-3) 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            margin-bottom: 12px;
            letter-spacing: -0.02em;
        }

        .header p {
            font-size: 1.05rem;
            color: var(--text-secondary);
            max-width: 600px;
            margin: 0 auto;
            line-height: 1.6;
        }

        /* ========== STEPPER ========== */
        .stepper {
            display: flex;
            justify-content: center;
            gap: 12px;
            margin-bottom: 40px;
        }

        .step-indicator {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 10px 20px;
            border-radius: 100px;
            background: var(--bg-card);
            border: 1px solid var(--border);
            font-size: 0.85rem;
            font-weight: 500;
            color: var(--text-muted);
            transition: var(--transition);
        }

        .step-indicator.active {
            background: linear-gradient(135deg, rgba(99, 102, 241, 0.2), rgba(139, 92, 246, 0.2));
            border-color: var(--accent-1);
            color: var(--accent-3);
            box-shadow: 0 0 20px var(--accent-glow);
        }

        .step-indicator.completed {
            background: var(--success-bg);
            border-color: var(--success);
            color: var(--success);
        }

        .step-num {
            width: 24px;
            height: 24px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 0.75rem;
            font-weight: 700;
            background: var(--bg-secondary);
            border: 1px solid currentColor;
        }

        .step-indicator.completed .step-num::after {
            content: '✓';
        }

        .step-connector {
            width: 40px;
            height: 2px;
            background: var(--border);
            align-self: center;
            border-radius: 2px;
            transition: var(--transition);
        }

        .step-connector.active {
            background: var(--accent-1);
        }

        /* ========== CARDS ========== */
        .card {
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: var(--radius-lg);
            padding: 32px;
            margin-bottom: 24px;
            box-shadow: var(--shadow);
            transition: var(--transition);
        }

        .card:hover {
            border-color: var(--border-active);
        }

        .card-title {
            font-size: 1.15rem;
            font-weight: 700;
            margin-bottom: 20px;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .card-title .icon {
            font-size: 1.3rem;
        }

        /* ========== UPLOAD AREA ========== */
        .upload-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
        }

        .upload-zone {
            border: 2px dashed var(--border);
            border-radius: var(--radius);
            padding: 32px 20px;
            text-align: center;
            cursor: pointer;
            transition: var(--transition);
            position: relative;
            overflow: hidden;
        }

        .upload-zone:hover {
            border-color: var(--accent-1);
            background: rgba(99, 102, 241, 0.05);
        }

        .upload-zone.has-file {
            border-color: var(--success);
            background: var(--success-bg);
        }

        .upload-zone input {
            display: none;
        }

        .upload-icon {
            font-size: 2.5rem;
            margin-bottom: 12px;
            display: block;
        }

        .upload-label {
            font-weight: 600;
            font-size: 0.95rem;
            color: var(--text-primary);
            margin-bottom: 4px;
        }

        .upload-hint {
            font-size: 0.8rem;
            color: var(--text-muted);
        }

        .upload-filename {
            margin-top: 8px;
            font-size: 0.8rem;
            color: var(--success);
            font-weight: 500;
        }

        /* ========== BUTTONS ========== */
        .btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            padding: 12px 28px;
            border: none;
            border-radius: 100px;
            font-family: inherit;
            font-size: 0.9rem;
            font-weight: 600;
            cursor: pointer;
            transition: var(--transition);
            letter-spacing: 0.02em;
        }

        .btn-primary {
            background: linear-gradient(135deg, var(--accent-1), var(--accent-2));
            color: white;
            box-shadow: 0 4px 16px var(--accent-glow);
        }

        .btn-primary:hover:not(:disabled) {
            transform: translateY(-2px);
            box-shadow: 0 6px 24px rgba(99, 102, 241, 0.4);
        }

        .btn-primary:disabled {
            opacity: 0.5;
            cursor: not-allowed;
            transform: none;
        }

        .btn-secondary {
            background: var(--bg-secondary);
            color: var(--text-secondary);
            border: 1px solid var(--border);
        }

        .btn-secondary:hover {
            background: var(--bg-card-hover);
            border-color: var(--border-active);
            color: var(--text-primary);
        }

        .btn-danger {
            background: var(--danger-bg);
            color: var(--danger);
            border: 1px solid rgba(239, 68, 68, 0.2);
        }

        .btn-danger:hover {
            background: rgba(239, 68, 68, 0.15);
        }

        .btn-group {
            display: flex;
            gap: 12px;
            justify-content: center;
            margin-top: 24px;
        }

        /* ========== CANVAS CONTAINER ========== */
        .canvas-section {
            display: none;
        }

        .canvas-wrapper {
            display: flex;
            justify-content: center;
            margin: 20px 0;
        }

        .canvas-container {
            position: relative;
            display: inline-block;
            border: 2px solid var(--border);
            border-radius: var(--radius);
            overflow: hidden;
            cursor: crosshair;
            box-shadow: var(--shadow-lg);
        }

        .canvas-container canvas {
            display: block;
        }

        .canvas-info {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 12px 16px;
            background: var(--bg-secondary);
            border-radius: var(--radius);
            margin-top: 12px;
            font-size: 0.85rem;
        }

        .point-count {
            display: flex;
            align-items: center;
            gap: 6px;
            color: var(--accent-3);
            font-weight: 600;
        }

        .canvas-hint {
            color: var(--text-muted);
            font-size: 0.8rem;
        }

        /* ========== RESULTS ========== */
        .results-section {
            display: none;
        }

        .results-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 24px;
            margin-bottom: 24px;
        }

        .ear-result-card {
            background: var(--bg-secondary);
            border-radius: var(--radius);
            overflow: hidden;
            border: 1px solid var(--border);
        }

        .ear-result-header {
            padding: 14px 20px;
            font-weight: 700;
            font-size: 0.9rem;
            letter-spacing: 0.02em;
        }

        .ear-result-header.right {
            background: linear-gradient(135deg, rgba(99, 102, 241, 0.15), rgba(139, 92, 246, 0.1));
            color: var(--accent-3);
            border-bottom: 1px solid rgba(99, 102, 241, 0.2);
        }

        .ear-result-header.left {
            background: linear-gradient(135deg, rgba(16, 185, 129, 0.15), rgba(52, 211, 153, 0.1));
            color: var(--success);
            border-bottom: 1px solid rgba(16, 185, 129, 0.2);
        }

        .ear-result-card img {
            width: 100%;
            height: auto;
            display: block;
        }

        /* ========== DISTANCE TABLE ========== */
        .distance-table-wrapper {
            overflow-x: auto;
        }

        .distance-table {
            width: 100%;
            border-collapse: separate;
            border-spacing: 0;
            font-size: 0.9rem;
        }

        .distance-table thead th {
            background: var(--bg-secondary);
            padding: 14px 20px;
            text-align: left;
            font-weight: 600;
            color: var(--text-secondary);
            font-size: 0.8rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            border-bottom: 1px solid var(--border);
        }

        .distance-table tbody td {
            padding: 14px 20px;
            border-bottom: 1px solid var(--border);
            color: var(--text-primary);
        }

        .distance-table tbody tr:last-child td {
            border-bottom: none;
        }

        .distance-table tbody tr:hover {
            background: rgba(99, 102, 241, 0.05);
        }

        .distance-table .pair-badge {
            display: inline-flex;
            align-items: center;
            gap: 4px;
            padding: 4px 10px;
            border-radius: 100px;
            background: rgba(99, 102, 241, 0.1);
            color: var(--accent-3);
            font-weight: 600;
            font-size: 0.8rem;
        }

        .distance-table .value-px {
            color: var(--text-primary);
            font-weight: 600;
            font-variant-numeric: tabular-nums;
        }

        .distance-table .value-cm {
            color: var(--success);
            font-weight: 700;
            font-variant-numeric: tabular-nums;
        }

        .total-row {
            background: linear-gradient(135deg, rgba(99, 102, 241, 0.08), rgba(139, 92, 246, 0.08));
        }

        .total-row td {
            font-weight: 700 !important;
            border-top: 2px solid var(--accent-1) !important;
        }

        /* ========== POINTS LIST ========== */
        .points-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 16px;
            margin-top: 20px;
        }

        .points-card {
            background: var(--bg-secondary);
            border-radius: var(--radius);
            padding: 16px;
            border: 1px solid var(--border);
        }

        .points-card h4 {
            font-size: 0.85rem;
            font-weight: 600;
            margin-bottom: 12px;
            color: var(--text-secondary);
        }

        .points-list {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
        }

        .point-chip {
            display: inline-flex;
            align-items: center;
            gap: 4px;
            padding: 4px 10px;
            border-radius: 100px;
            font-size: 0.78rem;
            font-weight: 500;
            font-variant-numeric: tabular-nums;
        }

        .point-chip.right-point {
            background: rgba(99, 102, 241, 0.1);
            color: var(--accent-3);
            border: 1px solid rgba(99, 102, 241, 0.2);
        }

        .point-chip.left-point {
            background: var(--success-bg);
            color: var(--success);
            border: 1px solid rgba(16, 185, 129, 0.2);
        }

        .point-chip .num {
            font-weight: 700;
        }

        /* ========== TOAST ========== */
        .toast {
            position: fixed;
            bottom: 24px;
            right: 24px;
            padding: 14px 24px;
            border-radius: var(--radius);
            font-size: 0.9rem;
            font-weight: 500;
            z-index: 1000;
            transform: translateY(120%);
            opacity: 0;
            transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
            max-width: 380px;
            box-shadow: var(--shadow-lg);
        }

        .toast.show {
            transform: translateY(0);
            opacity: 1;
        }

        .toast.success {
            background: var(--success);
            color: white;
        }

        .toast.error {
            background: var(--danger);
            color: white;
        }

        .toast.info {
            background: var(--accent-1);
            color: white;
        }

        /* ========== LOADING ========== */
        .loading-overlay {
            display: none;
            position: fixed;
            inset: 0;
            background: rgba(10, 14, 26, 0.85);
            backdrop-filter: blur(8px);
            z-index: 999;
            justify-content: center;
            align-items: center;
            flex-direction: column;
            gap: 20px;
        }

        .loading-overlay.show {
            display: flex;
        }

        .loader {
            width: 48px;
            height: 48px;
            border: 3px solid var(--border);
            border-top-color: var(--accent-1);
            border-radius: 50%;
            animation: spin 0.8s linear infinite;
        }

        @keyframes spin {
            to {
                transform: rotate(360deg);
            }
        }

        .loading-text {
            font-size: 1rem;
            font-weight: 500;
            color: var(--text-secondary);
        }

        /* ========== JSON PANEL ========== */
        .json-panel {
            background: var(--bg-secondary);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            overflow: hidden;
            margin-top: 24px;
        }

        .json-panel-header {
            padding: 12px 20px;
            background: var(--bg-card);
            font-weight: 600;
            font-size: 0.85rem;
            color: var(--text-secondary);
            cursor: pointer;
            display: flex;
            justify-content: space-between;
            align-items: center;
            user-select: none;
        }

        .json-panel-header:hover {
            background: var(--bg-card-hover);
        }

        .json-panel-body {
            display: none;
            padding: 16px 20px;
            max-height: 400px;
            overflow: auto;
        }

        .json-panel-body.open {
            display: block;
        }

        .json-panel-body pre {
            font-family: 'JetBrains Mono', 'Fira Code', monospace;
            font-size: 0.8rem;
            line-height: 1.6;
            color: var(--accent-3);
            white-space: pre-wrap;
            word-break: break-all;
        }

        /* ========== RESPONSIVE ========== */
        @media (max-width: 768px) {

            .upload-grid,
            .results-grid,
            .points-grid {
                grid-template-columns: 1fr;
            }

            .header h1 {
                font-size: 1.8rem;
            }

            .stepper {
                flex-wrap: wrap;
            }

            .app {
                padding: 12px;
            }

            .card {
                padding: 20px;
            }
        }

        @keyframes slideDown {
            from { opacity: 0; transform: translateY(-10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        /* ========== NEW VALIDATION STYLES ========== */
        .validation-modes .btn-secondary.active {
            background: rgba(99, 102, 241, 0.2);
            border-color: var(--accent-1);
            color: var(--accent-3);
        }

        .imp-card {
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: 8px;
            padding: 10px;
            font-size: 0.8rem;
        }

        .imp-card.needs-work {
            border-color: rgba(239, 68, 68, 0.3);
            background: rgba(239, 68, 68, 0.05);
        }

        .imp-card h5 {
            margin: 0 0 4px 0;
            color: var(--text-secondary);
        }

        .imp-card .val {
            font-weight: 700;
            margin-bottom: 2px;
        }

        .imp-card .hint {
            font-size: 0.7rem;
            color: var(--text-muted);
        }

        /* ========== WEBCAM MODAL ========== */
        .webcam-modal {
            display: none;
            position: fixed;
            inset: 0;
            background: rgba(10, 14, 26, 0.92);
            backdrop-filter: blur(10px);
            z-index: 998;
            justify-content: center;
            align-items: center;
            padding: 20px;
        }

        .webcam-modal.show {
            display: flex;
        }

        .webcam-box {
            background: var(--bg-card);
            border: 1px solid var(--border-active);
            border-radius: var(--radius-lg);
            padding: 28px;
            max-width: 960px;
            width: 100%;
            box-shadow: var(--shadow-lg);
        }

        .webcam-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
        }

        .webcam-header h3 {
            font-size: 1.1rem;
            font-weight: 700;
            color: var(--text-primary);
        }

        .webcam-feeds {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 16px;
            margin-bottom: 20px;
        }

        .webcam-feed-box {
            background: var(--bg-secondary);
            border-radius: var(--radius);
            overflow: hidden;
            border: 1px solid var(--border);
        }

        .webcam-feed-label {
            padding: 8px 14px;
            font-size: 0.8rem;
            font-weight: 600;
            color: var(--text-secondary);
            background: var(--bg-card);
            border-bottom: 1px solid var(--border);
        }

        .webcam-feed-box video,
        .webcam-feed-box img#annotatedImg {
            width: 100%;
            height: auto;
            display: block;
            min-height: 180px;
            object-fit: cover;
            background: #000;
        }

        .guidance-panel {
            background: var(--bg-secondary);
            border-radius: var(--radius);
            padding: 14px 18px;
            border: 1px solid var(--border);
            margin-bottom: 16px;
        }

        .guidance-panel h4 {
            font-size: 0.85rem;
            font-weight: 600;
            color: var(--text-secondary);
            margin-bottom: 10px;
        }

        .guidance-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 6px 0;
            border-bottom: 1px solid var(--border);
            font-size: 0.85rem;
        }

        .guidance-row:last-child {
            border-bottom: none;
        }

        .g-point {
            font-weight: 700;
            color: var(--accent-3);
            min-width: 36px;
        }

        .g-msg {
            flex: 1;
            padding: 0 12px;
        }

        .g-msg.correct {
            color: var(--success);
        }

        .g-msg.wrong {
            color: #f59e0b;
        }

        .g-msg.missing {
            color: var(--danger);
        }

        .g-err {
            font-size: 0.78rem;
            color: var(--text-muted);
        }

        .ear-toggle {
            display: flex;
            gap: 8px;
            margin-bottom: 16px;
            justify-content: center;
        }

        .ear-toggle button {
            padding: 8px 24px;
            border-radius: 100px;
            border: 1px solid var(--border);
            background: var(--bg-secondary);
            color: var(--text-secondary);
            font-size: 0.85rem;
            font-weight: 600;
            cursor: pointer;
            transition: var(--transition);
            font-family: inherit;
            background: linear-gradient(135deg, var(--accent-1), var(--accent-2));
            color: white;
            border-color: var(--accent-1);
        }

        @media (max-width: 600px) {
            .webcam-feeds {
                grid-template-columns: 1fr;
            }
        }

        /* Improvement Scorecard */
        .improvement-report {
            display: none;
            background: rgba(16, 185, 129, 0.05);
            border: 1px solid var(--accent-1);
            border-radius: var(--radius);
            padding: 20px;
            margin-top: 15px;
            animation: slideIn 0.3s ease-out;
        }

        .improvement-report.show {
            display: block;
        }

        .score-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 15px;
        }

        .score-circle {
            width: 70px;
            height: 70px;
            border-radius: 50%;
            border: 4px solid var(--accent-1);
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            font-weight: 800;
        }

        .score-circle .pct {
            font-size: 1.2rem;
        }

        .score-circle .lbl {
            font-size: 0.6rem;
            text-transform: uppercase;
            color: var(--text-muted);
        }

        .improvement-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
            gap: 12px;
        }

        .imp-card {
            background: var(--bg-card);
            padding: 12px;
            border-radius: var(--radius-sm);
            border-left: 3px solid var(--accent-1);
        }

        .imp-card.needs-work {
            border-left-color: #f59e0b;
        }

        .imp-card h5 {
            font-size: 0.75rem;
            color: var(--text-muted);
            margin-bottom: 5px;
        }

        .imp-card .val {
            font-size: 1rem;
            font-weight: 700;
            color: var(--text-primary);
        }

        .imp-card .hint {
            font-size: 0.7rem;
            color: var(--accent-2);
            margin-top: 4px;
        }

        @keyframes slideIn {
            from {
                opacity: 0;
                transform: translateY(10px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
    </style>
</head>

<body>
    <div class="app">
        <!-- HEADER -->
        <div class="header">
            <div class="header-badge">Module 2 — Ear Landmark Mapping</div>
            <h1>🎯 Ear Landmark Mapper</h1>
            <p>Upload both ears, mark landmarks on the right ear, and get mirrored measurements on the left ear
                automatically.</p>
        </div>

        <!-- STEPPER -->
        <div class="stepper">
            <div class="step-indicator active" id="step1Indicator">
                <span class="step-num">1</span>
                Upload Images
            </div>
            <div class="step-connector" id="connector1"></div>
            <div class="step-indicator" id="step2Indicator">
                <span class="step-num">2</span>
                Mark Landmarks
            </div>
            <div class="step-connector" id="connector2"></div>
            <div class="step-indicator" id="step3Indicator">
                <span class="step-num">3</span>
                View Results
            </div>
        </div>

        <!-- STEP 1: UPLOAD -->
        <div class="card" id="uploadCard">
            <div class="card-title">
                <span class="icon">📤</span>
                Upload Ear Images
            </div>
            <div class="upload-grid">
                <label class="upload-zone" id="rightUploadZone" for="rightEarInput">
                    <input type="file" id="rightEarInput" accept="image/*">
                    <span class="upload-icon">👂</span>
                    <div class="upload-label">Right Ear</div>
                    <div class="upload-hint">Click to browse or drag & drop</div>
                    <div class="upload-filename" id="rightFileName"></div>
                </label>
                <label class="upload-zone" id="leftUploadZone" for="leftEarInput">
                    <input type="file" id="leftEarInput" accept="image/*">
                    <span class="upload-icon">👂</span>
                    <div class="upload-label">Left Ear</div>
                    <div class="upload-hint">Click to browse or drag & drop</div>
                    <div class="upload-filename" id="leftFileName"></div>
                </label>
            </div>
            <div class="btn-group">
                <button class="btn btn-primary" id="segmentBtn" onclick="segmentEars()" disabled>
                    🔬 Segment & Normalize
                </button>
            </div>
        </div>

        <!-- STEP 2: MARK LANDMARKS -->
        <div class="card canvas-section" id="canvasCard">
            <div class="card-title">
                <span class="icon">📌</span>
                Mark Landmarks on Right Ear
            </div>
            <p style="color: var(--text-secondary); margin-bottom: 16px; font-size: 0.9rem;">
                Click on the right ear image below to place landmark points in order.
                These will be mirrored to the left ear automatically.
            </p>
            <div class="canvas-wrapper">
                <div class="canvas-container" id="canvasContainer">
                    <canvas id="earCanvas" width="256" height="256"></canvas>
                </div>
            </div>
            <div class="canvas-info">
                <div class="point-count">
                    <span>📍</span>
                    <span id="pointCountText">0 points placed</span>
                </div>
                <div class="canvas-hint">Left click to add • Right click to undo last</div>
            </div>
            <div class="btn-group">
                <button class="btn btn-danger" onclick="clearPoints()">🗑️ Clear All</button>
                <button class="btn btn-secondary" onclick="undoLastPoint()">↩️ Undo Last</button>
                <button class="btn btn-primary" id="measureBtn" onclick="mirrorAndMeasure()" disabled>
                    📏 Mirror & Measure
                </button>
            </div>
        </div>

        <!-- STEP 3: RESULTS -->
        <div class="card results-section" id="resultsCard">
            <div class="card-title">
                <span class="icon">📊</span>
                Measurement Results
            </div>

            <!-- STEP 3 VALIDATION OPTIONS -->
            <div class="validation-modes" style="margin-bottom: 32px; padding: 20px; background: rgba(255,255,255,0.02); border-radius: var(--radius); border: 1px solid var(--border);">
                <div style="font-size: 0.85rem; color: var(--text-secondary); text-align: center; margin-bottom: 12px; font-weight: 600;">
                    CHOOSE VALIDATION METHOD
                </div>
                
                <div style="display: flex; justify-content: center; gap: 8px; margin-bottom: 20px;">
                    <button id="valToggleLeft" class="btn btn-secondary active" onclick="setGlobalEarSide('left')" style="padding: 6px 16px; font-size: 0.8rem; border-radius: 6px;">👂 Left Ear</button>
                    <button id="valToggleRight" class="btn btn-secondary" onclick="setGlobalEarSide('right')" style="padding: 6px 16px; font-size: 0.8rem; border-radius: 6px;">👂 Right Ear</button>
                </div>
                
                <div style="display: flex; gap: 12px; justify-content: center; flex-wrap: wrap;">
                    <button class="btn btn-primary" id="openWebcamBtn" onclick="openWebcam()"
                        style="background:linear-gradient(135deg,#10b981,#059669); flex: 1; min-width: 200px; font-size: 0.85rem;">
                        🎥 Real-time Webcam
                    </button>
                    <!-- NEW: SINGLE IMAGE TEST BUTTON -->
                    <button class="btn btn-secondary" id="testImageBtn" onclick="document.getElementById('validationImageInput').click()"
                        style="flex: 1; min-width: 200px; font-size: 0.85rem; background: rgba(99, 102, 241, 0.1); border-color: var(--accent-1); color: var(--accent-3);">
                        📁 Test with Image
                    </button>
                    <input type="file" id="validationImageInput" accept="image/*" style="display: none;" onchange="validateWithImage(this)">
                </div>
            </div>



            <!-- Ear Images with Landmarks -->
            <div class="results-grid" id="resultImages"></div>

            <!-- Points Coordinates -->
            <div class="points-grid" id="pointsDisplay"></div>

            <!-- Distances Table -->
            <div class="distance-table-wrapper" style="margin-top: 24px;">
                <table class="distance-table" id="distanceTable">
                    <thead>
                        <tr>
                            <th>Pair</th>
                            <th>Distance (px)</th>
                            <th>Distance (cm)</th>
                        </tr>
                    </thead>
                    <tbody id="distanceBody"></tbody>
                </table>
            </div>

            <!-- JSON Response (Collapsible) -->
            <div class="json-panel">
                <div class="json-panel-header" onclick="toggleJson()">
                    <span>📋 Raw JSON Response</span>
                    <span id="jsonToggleIcon">▸</span>
                </div>
                <div class="json-panel-body" id="jsonBody">
                    <pre id="jsonContent"></pre>
                </div>
            </div>

            <div class="btn-group">
                <button class="btn btn-secondary" onclick="goBackToLandmarks()">↩️ Re-mark Landmarks</button>
                <button class="btn btn-danger" onclick="resetAll()">🔄 Start Over</button>
            </div>
        </div>
    </div>

    <!-- WEBCAM MODAL -->
    <div class="webcam-modal" id="webcamModal">
        <div class="webcam-box">
            <div class="webcam-header">
                <h3>🎥 Live Webcam Validation</h3>
                <button class="btn btn-danger" onclick="stopWebcam()" style="padding:8px 18px;">✕ Close</button>
            </div>

            <!-- Toggle L / R ear -->
            <div class="ear-toggle">
                <button id="toggleLeft" class="active" onclick="setEarSide('left')">👂 Left Ear</button>
                <button id="toggleRight" onclick="setEarSide('right')">👂 Right Ear</button>
            </div>

            <!-- Dual feeds -->
            <div class="webcam-feeds">
                <div class="webcam-feed-box">
                    <div class="webcam-feed-label">📷 Your Webcam</div>
                    <video id="webcamVideo" autoplay playsinline muted></video>
                    <canvas id="captureCanvas" style="display:none;"></canvas>
                </div>
                <div class="webcam-feed-box">
                    <div class="webcam-feed-label">🤖 AI Annotated View</div>
                    <img id="annotatedImg" src="" alt="Waiting for frame..." style="min-height:200px; background:#000;">
                </div>
            </div>

            <!-- Capture Controls -->
            <div style="text-align:center; margin-bottom: 15px; margin-top: 15px;">
                <button class="btn btn-primary" id="analyzeBtn" onclick="captureSnapshot()"
                    style="padding: 12px 30px; font-size: 1rem; width: 100%;">
                    📸 Capture & Analyze Snapshot
                </button>
            </div>

            <!-- Improvement Report (Hidden by default) -->
            <div class="improvement-report" id="improvementReport">
                <div class="score-header">
                    <div>
                        <h4 style="margin:0; color:var(--text-primary);">Detailed Improvement Plan</h4>
                        <p id="overallStatus"
                            style="margin:0; font-size:0.85rem; color:var(--accent-1); font-weight:600;"></p>
                    </div>
                    <div class="score-circle">
                        <span class="pct" id="accuracyPct">0%</span>
                        <span class="lbl">Acurracy</span>
                    </div>
                </div>
                <div id="prepiercingAction" style="display:none; margin-top: 20px;">
                    <button class="btn btn-primary" onclick="declarePrepiercing()" 
                        style="background: linear-gradient(135deg, #8b5cf6, #6366f1); width: 100%; font-weight: 700;">
                        🌟 Declare as Pre-piercing Baseline
                    </button>
                </div>
            </div>

            <p style="font-size:0.78rem; color:var(--text-muted); text-align:center; margin-top: 15px;">
                Place <strong style="color:var(--text-primary);">blue markers</strong> on the physical ear and hold it in front of
                the camera.
                Black rings = digital targets &nbsp;|&nbsp; Solid blue dots = detected markers
            </p>
        </div>
    </div>

    <!-- LOADING OVERLAY -->
    <div class="loading-overlay" id="loadingOverlay">
        <div class="loader"></div>
        <div class="loading-text" id="loadingText">Processing...</div>
    </div>

    <!-- TOAST -->
    <div class="toast" id="toast"></div>

    <script>
        // ==================== CONFIG ====================
        const API_URL = "http://localhost:8001";

        // ==================== STATE ====================
        let rightFile = null;
        let leftFile = null;
        let sessionId = null;
        let rightEarImage = null; // base64
        let leftEarImage = null;  // base64
        let markedPoints = []; // [{x, y}, ...]
        let canvasImg = null;     // Image object for canvas
        const IMAGE_SIZE = 256;
        const CANVAS_SCALE = 2; // render canvas at 2x for retina
        const DISPLAY_SIZE = 384; // display size on screen

        // ==================== FILE INPUTS ====================
        document.getElementById("rightEarInput").addEventListener("change", (e) => {
            rightFile = e.target.files[0];
            if (rightFile) {
                document.getElementById("rightFileName").textContent = `✓ ${rightFile.name}`;
                document.getElementById("rightUploadZone").classList.add("has-file");
            }
            updateSegmentButton();
        });

        document.getElementById("leftEarInput").addEventListener("change", (e) => {
            leftFile = e.target.files[0];
            if (leftFile) {
                document.getElementById("leftFileName").textContent = `✓ ${leftFile.name}`;
                document.getElementById("leftUploadZone").classList.add("has-file");
            }
            updateSegmentButton();
        });

        function updateSegmentButton() {
            document.getElementById("segmentBtn").disabled = !(rightFile && leftFile);
        }

        // ==================== STEP 1: SEGMENT ====================
        async function segmentEars() {
            if (!rightFile || !leftFile) {
                showToast("Please select both ear images", "error");
                return;
            }

            const formData = new FormData();
            formData.append("rightEar", rightFile);
            formData.append("leftEar", leftFile);

            try {
                showLoading("Segmenting and normalizing ears...");

                const resp = await fetch(`${API_URL}/segment`, {
                    method: "POST",
                    body: formData,
                });

                if (!resp.ok) {
                    const err = await resp.json();
                    throw new Error(err.detail || "Segmentation failed");
                }

                const result = await resp.json();
                sessionId = result.data.session_id;
                rightEarImage = result.data.right_ear_image;
                leftEarImage = result.data.left_ear_image;

                // Set up canvas
                setupCanvas();

                // Move to step 2
                setStep(2);
                showToast("Ears segmented successfully!", "success");

            } catch (err) {
                showToast(err.message, "error");
            } finally {
                hideLoading();
            }
        }

        // ==================== CANVAS ====================
        function setupCanvas() {
            const canvas = document.getElementById("earCanvas");
            canvas.width = DISPLAY_SIZE;
            canvas.height = DISPLAY_SIZE;
            canvas.style.width = DISPLAY_SIZE + "px";
            canvas.style.height = DISPLAY_SIZE + "px";

            canvasImg = new window.Image();
            canvasImg.onload = () => {
                drawCanvas();
            };
            canvasImg.src = `data:image/png;base64,${rightEarImage}`;

            // Click to add point
            canvas.addEventListener("click", onCanvasClick);
            // Right-click to undo
            canvas.addEventListener("contextmenu", (e) => {
                e.preventDefault();
                undoLastPoint();
            });
        }

        function onCanvasClick(e) {
            const canvas = document.getElementById("earCanvas");
            const rect = canvas.getBoundingClientRect();

            // Scale click coordinates to IMAGE_SIZE space (256x256)
            const scaleX = IMAGE_SIZE / rect.width;
            const scaleY = IMAGE_SIZE / rect.height;
            const x = (e.clientX - rect.left) * scaleX;
            const y = (e.clientY - rect.top) * scaleY;

            markedPoints.push({ x: Math.round(x * 100) / 100, y: Math.round(y * 100) / 100 });
            drawCanvas();
            updatePointCount();
        }

        function drawCanvas() {
            const canvas = document.getElementById("earCanvas");
            const ctx = canvas.getContext("2d");

            // Clear
            ctx.clearRect(0, 0, canvas.width, canvas.height);

            // Draw image
            if (canvasImg && canvasImg.complete) {
                ctx.drawImage(canvasImg, 0, 0, canvas.width, canvas.height);
            }

            if (markedPoints.length === 0) return;

            const sx = canvas.width / IMAGE_SIZE;
            const sy = canvas.height / IMAGE_SIZE;

            // Draw connecting lines
            ctx.strokeStyle = "rgba(16, 185, 129, 0.7)";
            ctx.lineWidth = 2;
            for (let i = 0; i < markedPoints.length - 1; i++) {
                ctx.beginPath();
                ctx.moveTo(markedPoints[i].x * sx, markedPoints[i].y * sy);
                ctx.lineTo(markedPoints[i + 1].x * sx, markedPoints[i + 1].y * sy);
                ctx.stroke();
            }

            // Draw points
            markedPoints.forEach((pt, i) => {
                const px = pt.x * sx;
                const py = pt.y * sy;

                // Outer glow
                ctx.beginPath();
                ctx.arc(px, py, 10, 0, Math.PI * 2);
                ctx.fillStyle = "rgba(239, 68, 68, 0.25)";
                ctx.fill();

                // Circle
                ctx.beginPath();
                ctx.arc(px, py, 6, 0, Math.PI * 2);
                ctx.fillStyle = "#000000";
                ctx.fill();
                ctx.strokeStyle = "#fff";
                ctx.lineWidth = 1.5;
                ctx.stroke();

                // Label
                ctx.font = "bold 14px Inter, sans-serif";
                ctx.fillStyle = "#fbbf24";
                ctx.strokeStyle = "rgba(0,0,0,0.6)";
                ctx.lineWidth = 3;
                ctx.strokeText(`${i + 1}`, px + 10, py - 8);
                ctx.fillText(`${i + 1}`, px + 10, py - 8);
            });
        }

        function updatePointCount() {
            const n = markedPoints.length;
            document.getElementById("pointCountText").textContent = `${n} point${n !== 1 ? 's' : ''} placed`;
            document.getElementById("measureBtn").disabled = n < 1;
        }

        function clearPoints() {
            markedPoints = [];
            drawCanvas();
            updatePointCount();
        }

        function undoLastPoint() {
            if (markedPoints.length > 0) {
                markedPoints.pop();
                drawCanvas();
                updatePointCount();
            }
        }

        // ==================== STEP 2: MIRROR & MEASURE ====================
        async function mirrorAndMeasure() {
            if (markedPoints.length < 1) {
                showToast("Please mark at least 1 landmark", "error");
                return;
            }

            const payload = {
                session_id: sessionId,
                right_ear_points: markedPoints.map(p => ({ x: p.x, y: p.y })),
            };

            try {
                showLoading("Mirroring landmarks and calculating distances...");

                const resp = await fetch(`${API_URL}/mirror-and-measure`, {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify(payload),
                });

                if (!resp.ok) {
                    const err = await resp.json();
                    throw new Error(err.detail || "Measurement failed");
                }

                const result = await resp.json();
                displayResults(result);
                setStep(3);
                showToast("Measurement complete!", "success");

            } catch (err) {
                showToast(err.message, "error");
            } finally {
                hideLoading();
            }
        }

        // ==================== DISPLAY RESULTS ====================
        function displayResults(result) {
            const data = result.data;

            // --- Ear images with landmarks ---
            document.getElementById("resultImages").innerHTML = `
                <div class="ear-result-card">
                    <div class="ear-result-header right">👂 Right Ear — Landmarks</div>
                    <img src="data:image/png;base64,${data.right_ear.landmarks_image}" alt="Right Ear Landmarks">
                </div>
                <div class="ear-result-card">
                    <div class="ear-result-header left">👂 Left Ear — Mirrored Landmarks</div>
                    <img src="data:image/png;base64,${data.left_ear.landmarks_image}" alt="Left Ear Landmarks">
                </div>
            `;

            // --- Points display ---
            const rightChips = data.right_ear.points.map((p, i) =>
                `<span class="point-chip right-point"><span class="num">${i + 1}</span> (${p.x.toFixed(1)}, ${p.y.toFixed(1)})</span>`
            ).join("");

            const leftChips = data.left_ear.points.map((p, i) =>
                `<span class="point-chip left-point"><span class="num">${i + 1}</span> (${p.x.toFixed(1)}, ${p.y.toFixed(1)})</span>`
            ).join("");

            document.getElementById("pointsDisplay").innerHTML = `
                <div class="points-card">
                    <h4>Right Ear Points (Original)</h4>
                    <div class="points-list">${rightChips}</div>
                </div>
                <div class="points-card">
                    <h4>Left Ear Points (Mirrored)</h4>
                    <div class="points-list">${leftChips}</div>
                </div>
            `;

            // --- Distances table ---
            let rows = data.distances.map(d => `
                <tr>
                    <td><span class="pair-badge">${d.from_point} → ${d.to_point}</span></td>
                    <td class="value-px">${d.distance_pixels.toFixed(3)}</td>
                    <td class="value-cm">${d.distance_cm.toFixed(3)} cm</td>
                </tr>
            `).join("");

            // Total row
            const totalRow = `
                <tr class="total-row">
                    <td><strong>Total</strong></td>
                    <td class="value-px"><strong>${data.total_distance.pixels.toFixed(3)}</strong></td>
                    <td class="value-cm"><strong>${data.total_distance.cm.toFixed(3)} cm</strong></td>
                </tr>
            `;

            document.getElementById("distanceBody").innerHTML = rows + totalRow;

            // --- JSON ---
            document.getElementById("jsonContent").textContent = JSON.stringify(result, null, 2);
        }

        // ==================== STEP MANAGEMENT ====================
        function setStep(step) {
            // stepper indicators
            ["step1Indicator", "step2Indicator", "step3Indicator"].forEach((id, i) => {
                const el = document.getElementById(id);
                el.classList.remove("active", "completed");
                if (i + 1 < step) el.classList.add("completed");
                if (i + 1 === step) el.classList.add("active");
            });

            document.getElementById("connector1").classList.toggle("active", step >= 2);
            document.getElementById("connector2").classList.toggle("active", step >= 3);

            // card visibility
            document.getElementById("uploadCard").style.display = step === 1 ? "block" : "none";
            document.getElementById("canvasCard").style.display = step === 2 ? "block" : "none";
            document.getElementById("canvasCard").classList.toggle("canvas-section", step !== 2);
            document.getElementById("resultsCard").style.display = step === 3 ? "block" : "none";
            document.getElementById("resultsCard").classList.toggle("results-section", step !== 3);
        }

        function goBackToLandmarks() {
            markedPoints = [];
            drawCanvas();
            updatePointCount();
            setStep(2);
        }

        function resetAll() {
            // Reset state
            rightFile = null;
            leftFile = null;
            sessionId = null;
            rightEarImage = null;
            leftEarImage = null;
            markedPoints = [];
            canvasImg = null;

            // Reset UI
            document.getElementById("rightEarInput").value = "";
            document.getElementById("leftEarInput").value = "";
            document.getElementById("rightFileName").textContent = "";
            document.getElementById("leftFileName").textContent = "";
            document.getElementById("rightUploadZone").classList.remove("has-file");
            document.getElementById("leftUploadZone").classList.remove("has-file");
            document.getElementById("segmentBtn").disabled = true;

            setStep(1);
            showToast("Reset complete", "info");
        }

        // ==================== JSON TOGGLE ====================
        function toggleJson() {
            const body = document.getElementById("jsonBody");
            const icon = document.getElementById("jsonToggleIcon");
            body.classList.toggle("open");
            icon.textContent = body.classList.contains("open") ? "▾" : "▸";
        }

        // ==================== LOADING ====================
        function showLoading(text) {
            document.getElementById("loadingText").textContent = text || "Processing...";
            document.getElementById("loadingOverlay").classList.add("show");
        }

        function hideLoading() {
            document.getElementById("loadingOverlay").classList.remove("show");
        }

        // ==================== TOAST ====================
        function showToast(msg, type = "info") {
            const toast = document.getElementById("toast");
            toast.textContent = msg;
            toast.className = `toast ${type}`;
            requestAnimationFrame(() => {
                toast.classList.add("show");
            });
            setTimeout(() => {
                toast.classList.remove("show");
            }, 3500);
        }

        // ==================== WEBCAM VALIDATION LOGIC ====================
        let webcamStream = null;
        let isWebcamRunning = false;
        let currentEarSide = 'left';
        let webcamInterval = null;

        async function openWebcam() {
            if (!sessionId) {
                showToast("No active session found", "error");
                return;
            }

            try {
                const stream = await navigator.mediaDevices.getUserMedia({
                    video: { width: 640, height: 480, facingMode: "user" }
                });

                webcamStream = stream;
                const video = document.getElementById("webcamVideo");
                video.srcObject = stream;

                document.getElementById("webcamModal").classList.add("show");
                isWebcamRunning = true;

                showToast("Webcam started - Align and click Capture", "success");
            } catch (err) {
                showToast("Camera access denied: " + err.message, "error");
                console.error(err);
            }
        }

        function stopWebcam() {
            isWebcamRunning = false;

            if (webcamStream) {
                webcamStream.getTracks().forEach(track => track.stop());
            }

            document.getElementById("webcamModal").classList.remove("show");
            document.getElementById("annotatedImg").src = "";
            document.getElementById("improvementReport").classList.remove("show");
        }

        function setGlobalEarSide(side) {
            currentEarSide = side;
            
            // Update Step 3 buttons
            document.getElementById("valToggleLeft").classList.toggle("active", side === 'left');
            document.getElementById("valToggleRight").classList.toggle("active", side === 'right');
            
            // Update Webcam Modal buttons
            document.getElementById("toggleLeft").classList.toggle("active", side === 'left');
            document.getElementById("toggleRight").classList.toggle("active", side === 'right');

            // Reset webcam state
            document.getElementById("improvementReport").classList.remove("show");
            document.getElementById("annotatedImg").src = "";
            const webBtn = document.getElementById("analyzeBtn");
            if (webBtn) {
                webBtn.innerHTML = "📸 Capture & Analyze Snapshot";
                webBtn.disabled = false;
            }

            showToast(`Target ear set to: ${side.toUpperCase()}`, "info");
        }

        // Bridge legacy setEarSide to new global one
        function setEarSide(side) { setGlobalEarSide(side); }


        // ==================== NEW: SINGLE IMAGE VALIDATION ====================
        async function validateWithImage(input) {
            if (!input.files || !input.files[0] || !sessionId) {
                if (!sessionId) showToast("No active session! Start by segmenting ears.", "error");
                return;
            }
            
            const file = input.files[0];
            const formData = new FormData();
            formData.append("file", file);
            formData.append("session_id", sessionId);
            formData.append("ear_side", currentEarSide);

            try {
                showLoading(`Analyzing ${currentEarSide} ear from image...`);
                const resp = await fetch(`${API_URL}/validate-frame`, {
                    method: "POST",
                    body: formData
                });

                if (!resp.ok) {
                    const err = await resp.json();
                    throw new Error(err.detail || "Validation failed");
                }

                const result = await resp.json();
                if (result.success && result.ear_detected) {
                    // Open the modal but prepare it for static view
                    if (isWebcamRunning) stopWebcam();
                    
                    document.getElementById("webcamModal").classList.add("show");
                    document.getElementById("webcamVideo").style.display = "none";
                    document.getElementById("analyzeBtn").style.display = "none";
                    
                    document.getElementById("annotatedImg").src = `data:image/png;base64,${result.annotated_image}`;
                    showImprovementReport(result);
                    
                    showToast(`Model Testing Complete! Alignment: ${result.summary.overall_accuracy}%`, "success");
                } else {
                    showToast("⚠️ No ear detected in the image. Try a better angle.", "error");
                }
            } catch (err) {
                showToast(err.message, "error");
                console.error(err);
            } finally {
                hideLoading();
                input.value = ""; // Reset file input
            }
        }
        
        // Update stopWebcam to reset the modal view
        const originalStopWebcam = stopWebcam;
        stopWebcam = function() {
            originalStopWebcam();
            document.getElementById("webcamVideo").style.display = "block";
            document.getElementById("analyzeBtn").style.display = "block";
        };



        let lastCapturedBlob = null;

        async function captureSnapshot() {
            if (!isWebcamRunning || !sessionId) return;

            const btn = document.getElementById("analyzeBtn");
            btn.innerHTML = "⏳ Analyzing Snapshot...";
            btn.disabled = true;

            const video = document.getElementById("webcamVideo");
            const canvas = document.getElementById("captureCanvas");
            const ctx = canvas.getContext("2d");

            canvas.width = video.videoWidth;
            canvas.height = video.videoHeight;
            ctx.drawImage(video, 0, 0, canvas.width, canvas.height);

            canvas.toBlob(async (blob) => {
                lastCapturedBlob = blob;
                const formData = new FormData();
                formData.append("file", blob, "frame.jpg");
                formData.append("session_id", sessionId);
                formData.append("ear_side", currentEarSide);

                try {
                    const resp = await fetch(`${API_URL}/validate-frame`, {
                        method: "POST",
                        body: formData
                    });

                    if (!resp.ok) {
                        showToast("API Error in validation", "error");
                        btn.innerHTML = "📸 Capture & Analyze Snapshot";
                        btn.disabled = false;
                        return;
                    }

                    const result = await resp.json();

                    if (result.success && result.ear_detected) {
                        document.getElementById("annotatedImg").src = `data:image/png;base64,${result.annotated_image}`;
                        showImprovementReport(result);
                        btn.innerHTML = "✅ Analysis Complete (Click to capture again)";
                    } else {
                        showToast("⚠️ No ear detected. Please align properly and try again.", "error");
                        btn.innerHTML = "📸 Capture & Analyze Snapshot";
                    }
                } catch (err) {
                    console.error("Analysis failed:", err);
                    showToast("Network Error", "error");
                    btn.innerHTML = "📸 Capture & Analyze Snapshot";
                }

                btn.disabled = false;
            }, "image/jpeg", 0.95); // High quality snapshot
        }

        function showImprovementReport(result) {
            const report = document.getElementById("improvementReport");
            const grid = document.getElementById("improvementGrid");
            const score = document.getElementById("accuracyPct");
            const status = document.getElementById("overallStatus");

            score.textContent = result.summary.overall_accuracy + "%";
            status.textContent = `Status: ${result.summary.status} (${result.summary.detected_markers}/${result.summary.total_points} markers detected)`;

            grid.innerHTML = result.guidance.map(g => {
                const needsWork = !g.correct && g.error_cm !== null;
                const errMm = g.error_cm ? (g.error_cm * 10).toFixed(1) : null;

                return `
                    <div class="imp-card ${needsWork ? 'needs-work' : ''}">
                        <h5>Point ${g.point}</h5>
                        <div class="val">${g.correct ? '✅ PERFECT' : (errMm ? errMm + 'mm Error' : '❌ NOT FOUND')}</div>
                        <div class="hint">${g.message}</div>
                    </div>
                `;
            }).join("");

            report.classList.add("show");
            
            // Show declare button if accuracy is good (>70%)
            const actionDiv = document.getElementById("prepiercingAction");
            if (result.summary.overall_accuracy > 70) {
                actionDiv.style.display = "block";
            } else {
                actionDiv.style.display = "none";
            }
            
            showToast("Analysis report generated!", "success");
        }

        async function declarePrepiercing() {
            if (!lastCapturedBlob || !sessionId) return;

            const actionBtn = document.querySelector("#prepiercingAction button");
            const originalText = actionBtn.innerHTML;
            
            try {
                actionBtn.innerHTML = "⏳ Declaring Phase 2...";
                actionBtn.disabled = true;

                const formData = new FormData();
                formData.append("file", lastCapturedBlob, "prepiercing.jpg");
                formData.append("session_id", sessionId);

                const resp = await fetch(`${API_URL}/detect-prepiercing`, {
                    method: "POST",
                    body: formData
                });

                if (!resp.ok) throw new Error("Failed to declare pre-piercing");

                const result = await resp.json();
                
                if (result.is_prepiercing) {
                    showToast(result.message, "success");
                    actionBtn.innerHTML = "✅ Declared as Phase 2";
                    actionBtn.style.background = "var(--success)";
                    
                    // Optionally update the UI to show it's now in Phase 2
                    setTimeout(() => {
                        stopWebcam();
                        setStep(3); // Go back to results to see the baseline if added there
                    }, 2000);
                } else {
                    showToast(result.message, "error");
                    actionBtn.innerHTML = originalText;
                    actionBtn.disabled = false;
                }

            } catch (err) {
                console.error("Prepiercing declaration failed:", err);
                showToast("Error declaring pre-piercing", "error");
                actionBtn.innerHTML = originalText;
                actionBtn.disabled = false;
            }
        }

        // ==================== HEALTH CHECK ====================
        window.addEventListener("load", async () => {
            try {
                const resp = await fetch(`${API_URL}/health`);
                if (resp.ok) {
                    console.log("✓ Module 2 API is running");
                } else {
                    showToast("⚠️ API not responding. Start server: python fastapi_module_2/app.py", "error");
                }
            } catch {
                showToast("⚠️ Cannot connect to API. Run: python fastapi_module_2/app.py", "error");
            }
        });
    </script>
</body>

</html>